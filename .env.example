# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Dropbox (optional — needed for /search Dropbox integration)
DROPBOX_ACCESS_TOKEN=your-dropbox-token

# Claude model (optional — defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Priorities URL (optional — published Simplenote or any URL with your priorities list)
PRIORITIES_URL=

# Digest schedule (optional — defaults to 5:30 AM in your Google Calendar timezone)
DIGEST_HOUR=5
DIGEST_MINUTE=30

# Feature toggles
# Set to false for calendar-only mode (no Gmail scanning or email tools)
ENABLE_EMAIL=true

# Google credentials: place credentials.json (OAuth client) in this directory.
# token.json is auto-generated after first OAuth flow.
